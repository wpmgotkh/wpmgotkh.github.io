---
title: Wilson Family Project
layout: templates/base.njk
---

  <div class="prosey">
    <p>This website catalogs information about my family tree. I'm sharing it here in case it might be useful to others who share a common lineage.</p>

    <h2>Search</h2>
  </div>

  <div class="">
    <form id="form" class="max-w-md">
      <label for="default-search" class="mb-2 text-sm font-medium text-gray-900 sr-only dark:text-white">Search</label>
      <div class="relative">
          <div class="absolute inset-y-0 start-0 flex items-center ps-4 pointer-events-none">
              <svg class="w-4 h-4 text-gray-400 dark:text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"/>
              </svg>
          </div>
          <input type="search" name="search" id="default-search" autocomplete="off" class="block w-full py-3 ps-10 pe-10 text-sm text-gray-900 border border-gray-300 rounded-full bg-gray-50 shadow-sm transition-shadow focus:shadow-md focus:ring-2 focus:ring-blue-400 focus:border-blue-400 focus:outline-none dark:bg-gray-800 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white" placeholder="Search for a person's name…" required />
          <button type="button" id="search-clear" aria-label="Clear search" class="hidden absolute inset-y-0 end-0 flex items-center pe-4 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300">
              <svg class="w-4 h-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l8 8m0-8-8 8"/>
              </svg>
          </button>
      </div>
    </form>

    <p id="search-hint" class="mt-2 text-xs text-gray-500 dark:text-gray-400"></p>

    <div id="results" class="prosey mt-4"></div>
  </div>

  <div class="prosey" id="homepage-content">
    {{content | safe}}
  </div>

  <script type="text/javascript" src="/assets/js/index.js"></script>
